{
  "$schema": "./node_modules/@angular/service-worker/config/schema.json",
  "index": "/index.html",
  "assetGroups": [
    {
      "name": "app",
      "installMode": "prefetch",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/favicon.ico",
          "/index.csr.html",
          "/index.html",
          "/manifest.webmanifest",
          "/*.css",
          "/*.js"
        ]
      }
    },
    {
      "name": "assets",
      "installMode": "lazy",
      "updateMode": "prefetch",
      "resources": {
        "files": [
          "/**/*.(svg|cur|jpg|jpeg|png|apng|webp|avif|gif|otf|ttf|woff|woff2)"
        ]
      }
    }
  ],
  "dataGroups": [
    {
      "name": "api-offline-audio-calls",
      "urls": [
        "https://localhost:7203/api/audio-books/*/audio*isOffline=True*",
        "https://localhost:7203/api/podcasts/*/episodes/*/audio*isOffline=True*"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 1000,
        "maxAge": "365d",
        "timeout": "10s"
      }
    },
    {
      "name": "api-offline-media-calls",
      "urls": [
        "https://localhost:7203/api/audio-books/*/cover*isOffline=True*",
        "https://localhost:7203/api/podcasts/*/cover*isOffline=True*",
        "https://localhost:7203/api/podcasts/*/episodes/*/cover*isOffline=True*",
        "https://localhost:7203/api/creators/*/cover*isOffline=True*"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 1000,
        "maxAge": "365d",
        "timeout": "10s"
      }
    },
    {
      "name": "api-offline-data-calls",
      "urls": [
        "https://localhost:7203/api/audio-books/*isOffline=True*",
        "https://localhost:7203/api/podcasts/*isOffline=True*",
        "https://localhost:7203/api/podcasts/*/episodes/*isOffline=True*",
        "https://localhost:7203/api/creators/*isOffline=True*"
      ],
      "cacheConfig": {
        "strategy": "performance",
        "maxSize": 1000,
        "maxAge": "365d",
        "timeout": "5s"
      }
    }
  ]
}